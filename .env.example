# Server configuration
PORT=3000

# MongoDB Atlas connection string (optional, leave blank for in-memory DB)
MONGODB_URI=

# Upstash Redis configuration (REST API) - optional
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Local / Container Redis (TCP) - optional
# Example: REDIS_URL=redis://localhost:6379
REDIS_URL=

# JWT Secret for cookie/session signing
JWT_SECRET=some_very_long_random_string_make_sure_it_is_secure_12345

